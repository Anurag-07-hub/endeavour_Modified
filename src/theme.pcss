@theme {
  --font-sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --font-display: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --font-mono: "Courier New", Courier, monospace;

  /* Original Website Colors mapping */
  --color-brand-accent: #a40505;
  --color-brand-bg: #ffffff;
  --color-brand-muted: rgba(0, 0, 0, 0.85);

  /* Invert Tailwind definitions to map light theme over the dark components */
  --color-white: #080808;
  --color-black: #ffffff;
}
